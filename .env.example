# Database
DATABASE_URL="postgresql://user:password@localhost:5432/cavree?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Razorpay (use live keys in production)
RAZORPAY_KEY_ID="rzp_test_xxx"
RAZORPAY_KEY_SECRET=""

# AWS
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# S3 & CloudFront (use CLOUDFRONT_URL with https:// prefix, e.g. https://dxxxx.cloudfront.net)
S3_BUCKET_NAME="cavree-images"
CLOUDFRONT_URL="https://your-cloudfront-domain.cloudfront.net"

# Domain Config
MAIN_DOMAIN="cavree.com"
NEXT_PUBLIC_APP_URL="https://cavree.com"

# Email
FROM_EMAIL="noreply@cavree.com"
ADMIN_EMAIL="admin@cavree.com"
