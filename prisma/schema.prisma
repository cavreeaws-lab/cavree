generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  FRANCHISEE
  FRANCHISE_STAFF
  SALES_EXECUTIVE
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  COD
}

enum ShippingStatus {
  PENDING
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
}

enum ProductMediaType {
  IMAGE
  VIDEO
}

enum PayoutStatus {
  PENDING
  APPROVED
  PAID
}

enum CommissionCreditStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  phone         String?
  image         String?
  role          UserRole  @default(CUSTOMER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  franchise            Franchise?
  addresses            Address[]
  orders               Order[]
  cart                 Cart?
  wishlist             Wishlist?
  reviews              Review[]
  payouts              Payout[]
  walletTransactions   WalletTransaction[]
  retailerProfile      Retailer?              @relation("RetailerUser")
  assignedRetailers    Retailer[]             @relation("RetailerSalesExecutive")
  bulkCart             BulkCart?
  bulkOrders           BulkOrder[]
  warehouseAssignments WarehouseCoordinator[]
  commissionCredits    CommissionCredit[]
  franchiseStaff       FranchiseStaff?
  stockAdjustments     StockAdjustment[]
  customerNotes        CustomerNote[]         @relation("CustomerNoteUser")
  customerNotesCreated CustomerNote[]         @relation("CustomerNoteCreator")
  returnRequests       ReturnRequest[]        @relation("ReturnRequestUser")
  returnArbitrations   ReturnRequest[]        @relation("ReturnRequestArbitrator")
  notifications        Notification[]
  recentlyViewed     RecentlyViewed[]
  pushSubscriptions    PushSubscription[]
  couponUsages         CouponUsage[]
  supportTickets       SupportTicket[]
  activityLogs         ActivityLog[]
  stockMovements       StockMovement[]
  franchiseApplications FranchiseApplication[]

  @@map("users")
}

model Franchise {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String?
  logo             String?
  banner           String?
  address          String?
  city             String?
  state            String?
  pincode          String?
  phone            String?
  email            String?
  commission       Float    @default(10.0)
  isActive         Boolean  @default(true)
  isApproved       Boolean  @default(false)
  isMainStore      Boolean  @default(false)
  autoAcceptOrders Boolean  @default(false)
  latitude         Float?
  longitude        Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ownerId String   @unique
  owner   User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  payouts Payout[]

  products           Product[]
  orders             Order[]
  retailers          Retailer[]
  agreements         FranchiseAgreement[]
  warehouses         Warehouse[]
  commissionRules    CommissionRule[]
  staff              FranchiseStaff[]
  walletTransactions FranchiseWalletTransaction[]
  productStocks      ProductFranchiseStock[]
  shippingConfig     VendorShippingConfig?

  @@map("franchises")
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@map("categories")
}

model Product {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  description          String?
  sku                  String   @unique
  modelNumber          String?
  productType          String?
  shirtType            String?
  brand                String?
  barcode              String?
  price                Float
  comparePrice         Float?
  costPrice            Float?
  singlePiecePrice     Float?
  franchiseBulkPrice   Float?
  minimumQuantityLimit Int?
  quantity             Int      @default(0)
  weight               Float?
  dimensions           Json?
  trackQuantity        Boolean  @default(true)
  allowBackorders      Boolean  @default(false)
  lowStockThreshold    Int      @default(5)
  isActive             Boolean  @default(true)
  isFeatured           Boolean  @default(false)
  isNew                Boolean  @default(false)
  tags                 String[]
  metaTitle            String?
  metaDescription      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  images         ProductImage[]
  media          ProductMedia[]
  variants       ProductVariant[]
  orderItems     OrderItem[]
  cartItems      CartItem[]
  wishlistItems  WishlistItem[]
  reviews        Review[]
  recentlyViewed RecentlyViewed[]
  returnItems    ReturnRequest[]
  productStocks  ProductFranchiseStock[]
  stockAdjustments StockAdjustment[]

  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductMedia {
  id        String           @id @default(cuid())
  type      ProductMediaType @default(IMAGE)
  url       String
  posterUrl String?
  alt       String?
  sortOrder Int              @default(0)
  productId String
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([productId, sortOrder])
  @@map("product_media")
}

model ProductVariant {
  id         String      @id @default(cuid())
  size       String?
  color      String?
  colorCode  String?
  sku        String      @unique
  price      Float?
  quantity   Int         @default(0)
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  stockAdjustments StockAdjustment[]
  cartItems  CartItem[]

  @@map("product_variants")
}

model Address {
  id        String  @id @default(cuid())
  name      String
  phone     String
  address   String
  city      String
  state     String
  pincode   String
  country   String  @default("India")
  isDefault Boolean @default(false)
  type      String  @default("HOME")

  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id        String         @id @default(cuid())
  quantity  Int            @default(1)
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("cart_items")
}

model Order {
  id             String      @id @default(cuid())
  orderNumber    String      @unique
  idempotencyKey String?     @unique
  status         OrderStatus @default(PENDING)
  subtotal       Float
  discount       Float       @default(0)
  shipping       Float       @default(0)
  tax            Float       @default(0)
  total          Float
  couponCode     String?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id])
  addressId String
  address   Address @relation(fields: [addressId], references: [id])

  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id])

  routedAt            DateTime?
  routingReason       String?

  items          OrderItem[]
  payment        Payment?
  shippingDetail Shipping?
  invoices       Invoice[]
  returns        ReturnRequest[]
  walletTransactions WalletTransaction[]

  @@map("orders")
}

model OrderItem {
  id        String          @id @default(cuid())
  name      String
  sku       String
  price     Float
  quantity  Int
  total     Float
  size      String?
  color     String?
  orderId   String
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?
  gatewayData   Json?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Shipping {
  id                       String         @id @default(cuid())
  status                   ShippingStatus @default(PENDING)
  carrier                  String?
  trackingNumber           String?
  trackingUrl              String?
  estimatedDate            DateTime?
  shippedAt                DateTime?
  deliveredAt              DateTime?
  shiprocketOrderId        String?
  shiprocketShipmentId     String?
  shiprocketTrackingUrl    String?
  shiprocketCourierName    String?
  shiprocketEwayBillNumber String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("shipping")
}

model Coupon {
  id               String    @id @default(cuid())
  code             String    @unique
  description      String?
  type             String    @default("PERCENTAGE")
  value            Float
  minOrder         Float     @default(0)
  maxDiscount      Float?
  usageLimit       Int?
  perCustomerLimit Int?
  usageCount       Int       @default(0)
  startDate        DateTime
  endDate          DateTime?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  usages CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String?
  discount  Float
  createdAt DateTime @default(now())

  @@index([couponId, userId])
  @@map("coupon_usages")
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  title      String?
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Wishlist {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([wishlistId, productId])
  @@map("wishlist_items")
}

model ContentBlock {
  id        String   @id @default(cuid())
  key       String   @unique
  type      String   @default("TEXT")
  content   String?
  metadata  Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("content_blocks")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  group     String   @default("GENERAL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model FranchiseApplication {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String
  city       String
  investment String
  space      String
  status     String   @default("PENDING")
  notes      String?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("franchise_applications")
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  ctaLabel  String?
  image     String
  link      String?
  position  String   @default("HOME_TOP")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

model Page {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  content         String?
  metaTitle       String?
  metaDescription String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("pages")
}

model StockAdjustment {
  id        String   @id @default(cuid())
  quantity  Int
  reason    String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("stock_adjustments")
}

model CustomerNote {
  id        String   @id @default(cuid())
  note      String
  userId    String
  user      User     @relation("CustomerNoteUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy String
  creator   User     @relation("CustomerNoteCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customer_notes")
}

model ReturnRequest {
  id                  String    @id @default(cuid())
  orderId             String
  order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId           String?
  product             Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  userId              String
  user                User      @relation("ReturnRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  type                String    @default("RETURN")
  reason              String
  status              String    @default("PENDING")
  notes               String?
  arbitrationDecision String?
  arbitrationNote     String?
  arbitratedAt        DateTime?
  arbitratedBy        String?
  arbitrator          User?     @relation("ReturnRequestArbitrator", fields: [arbitratedBy], references: [id], onDelete: SetNull)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([orderId])
  @@index([userId])
  @@map("return_requests")
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  url           String?
  issuedAt      DateTime @default(now())
  createdAt     DateTime @default(now())

  @@map("invoices")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

model WalletTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  type        String
  status      String   @default("PENDING")
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("wallet_transactions")
}

model Payout {
  id             String       @id @default(cuid())
  franchiseId    String
  userId         String
  amount         Float
  commission     Float        @default(0)
  status         PayoutStatus @default(PENDING)
  method         String?
  accountDetails Json?
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@map("payouts")
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("recently_viewed")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  subject   String
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

model Retailer {
  id                  String   @id @default(cuid())
  businessName        String
  ownerName           String
  email               String   @unique
  phone               String
  gstNumber           String?
  address             String?
  city                String?
  state               String?
  categoryInterests   String[]
  membershipTier      String   @default("STANDARD")
  status              String   @default("PENDING")
  franchiseCode       String   @unique
  paymentStatus       String   @default("PENDING")
  agreementStatus     String   @default("PENDING")
  renewalStatus       String   @default("NOT_DUE")
  warehouseStockValue Float    @default(0)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  userId String? @unique
  user   User?   @relation("RetailerUser", fields: [userId], references: [id], onDelete: SetNull)

  salesExecutiveId String?
  salesExecutive   User?   @relation("RetailerSalesExecutive", fields: [salesExecutiveId], references: [id], onDelete: SetNull)

  franchiseId String?
  franchise   Franchise? @relation(fields: [franchiseId], references: [id], onDelete: SetNull)

  bulkOrders        BulkOrder[]
  commissionCredits CommissionCredit[]

  @@index([status])
  @@index([salesExecutiveId])
  @@map("retailers")
}

model BulkProduct {
  id               String   @id @default(cuid())
  productId        String   @unique
  name             String
  slug             String   @unique
  description      String?
  category         String
  image            String?
  media            Json?
  singlePiecePrice Float    @default(0)
  wholesalePrice   Float
  unitSize         Int      @default(1000)
  minUnits         Int      @default(1)
  availableUnits   Int      @default(0)
  specs            Json?
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  units      BulkProductUnit[]
  cartItems  BulkCartItem[]
  orderItems BulkOrderItem[]

  @@index([category, isActive])
  @@map("bulk_products")
}

model BulkProductUnit {
  id        String      @id @default(cuid())
  unitCode  String      @unique
  status    String      @default("AVAILABLE")
  productId String
  product   BulkProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([productId, status])
  @@map("bulk_product_units")
}

model BulkCart {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     BulkCartItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("bulk_carts")
}

model BulkCartItem {
  id                String      @id @default(cuid())
  unitCount         Int         @default(1)
  unitSize          Int         @default(1000)
  unitPrice         Float
  selectedUnitCodes String[]
  total             Float
  cartId            String
  cart              BulkCart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId         String
  product           BulkProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([cartId, productId])
  @@map("bulk_cart_items")
}

model BulkOrder {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  franchiseCode   String
  status          String   @default("PENDING")
  paymentStatus   String   @default("PENDING")
  paymentMethod   String?
  subtotal        Float
  tax             Float    @default(0)
  total           Float
  totalUnits      Int      @default(0)
  totalPieces     Int      @default(0)
  deliveryName    String?
  deliveryPhone   String?
  deliveryAddress String?
  deliveryCity    String?
  deliveryState   String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  retailerId String?
  retailer   Retailer? @relation(fields: [retailerId], references: [id], onDelete: SetNull)

  items    BulkOrderItem[]
  timeline BulkOrderTimeline[]

  @@index([franchiseCode])
  @@index([status])
  @@map("bulk_orders")
}

model BulkOrderItem {
  id                String       @id @default(cuid())
  name              String
  productCode       String
  unitCount         Int
  unitSize          Int
  unitPrice         Float
  total             Float
  selectedUnitCodes String[]
  orderId           String
  order             BulkOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId         String?
  product           BulkProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("bulk_order_items")
}

model BulkOrderTimeline {
  id        String    @id @default(cuid())
  status    String
  title     String
  note      String?
  createdAt DateTime  @default(now())
  orderId   String
  order     BulkOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("bulk_order_timeline")
}

model FranchiseAgreement {
  id          String    @id @default(cuid())
  status      String    @default("PENDING")
  feeAmount   Float     @default(0)
  feeStatus   String    @default("PENDING")
  startsAt    DateTime?
  renewsAt    DateTime?
  documentUrl String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@index([franchiseId, status])
  @@map("franchise_agreements")
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  city      String?
  state     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  franchiseId String?
  franchise   Franchise? @relation(fields: [franchiseId], references: [id], onDelete: SetNull)

  coordinators WarehouseCoordinator[]
  movements    StockMovement[]

  @@map("warehouses")
}

model WarehouseCoordinator {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("warehouse_coordinators")
}

model StockMovement {
  id          String   @id @default(cuid())
  productCode String?
  productName String
  quantity    Int
  type        String
  reason      String?
  createdBy   String?
  creator     User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  @@index([type])
  @@map("stock_movements")
}

model CommissionRule {
  id        String   @id @default(cuid())
  name      String
  rate      Float
  appliesTo String   @default("FRANCHISE")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  franchiseId String?
  franchise   Franchise? @relation(fields: [franchiseId], references: [id], onDelete: SetNull)

  credits CommissionCredit[]

  @@map("commission_rules")
}

model CommissionCredit {
  id        String               @id @default(cuid())
  amount    Float
  rate      Float
  source    String
  status    CommissionCreditStatus @default(PENDING)
  notes     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  ruleId String?
  rule   CommissionRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  retailerId String?
  retailer   Retailer? @relation(fields: [retailerId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("commission_credits")
}

model BlogCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  excerpt         String?
  content         String?
  coverImage      String?
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  categoryId String?
  category   BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([isPublished, publishedAt])
  @@map("blog_posts")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id          String         @id @default(cuid())
  subject     String
  description String?
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  category    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId String?

  messages TicketMessage[]

  @@index([userId, status])
  @@index([orderId])
  @@map("support_tickets")
}

model TicketMessage {
  id          String   @id @default(cuid())
  message     String
  senderType  String   @default("CUSTOMER")
  attachments String[]
  createdAt   DateTime @default(now())

  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

enum FranchiseStaffRole {
  MANAGER
  STAFF
  ACCOUNTANT
  INVENTORY_MANAGER
}

model FranchiseStaff {
  id          String             @id @default(cuid())
  name        String
  email       String
  phone       String?
  role        FranchiseStaffRole @default(STAFF)
  permissions Json?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([franchiseId, email])
  @@map("franchise_staff")
}

model FranchiseWalletTransaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String
  status      String   @default("PENDING")
  description String?
  orderId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@map("franchise_wallet_transactions")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String
  p256dh    String
  auth      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

model ProductFranchiseStock {
  id                String   @id @default(cuid())
  quantity          Int      @default(0)
  lowStockThreshold Int      @default(5)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@unique([productId, franchiseId])
  @@map("product_franchise_stocks")
}

model VendorShippingConfig {
  id                    String   @id @default(cuid())
  name                  String
  zones                 Json?
  freeShippingThreshold Float?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  franchiseId String
  franchise   Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)

  @@unique([franchiseId])
  @@map("vendor_shipping_configs")
}
